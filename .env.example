# Copy to .env and adjust for local/docker compose
#
# Docker Compose overrides OLLAMA_BASE_URL and CHROMA_URL to internal hostnames.
# First `docker compose up --build` may take 5–15 min while Ollama pulls models.

# --- Host ports (published to your machine) ---
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=4000
CHROMA_HOST_PORT=8000
OLLAMA_HOST_PORT=11434

# --- Backend ---
NODE_ENV=development
PORT=4000

OLLAMA_BASE_URL=http://localhost:11434
# Must match a model from `ollama list` (e.g. llama3.2:latest or llama3.2:3b)
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION_PREFIX=wiki_article

# Chunking / retrieval
CHUNK_SIZE_CHARS=600
CHUNK_OVERLAP_CHARS=100
RAG_TOP_K=8
RAG_MIN_SCORE=0.1
LLM_TEMPERATURE=0.2

# Wikipedia scraper
WIKIPEDIA_HOST_ALLOWLIST=en.wikipedia.org
HTTP_TIMEOUT_MS=15000
OLLAMA_TIMEOUT_MS=300000
SUMMARIZE_MAX_CHARS=12000

# Frontend (leave empty when using Vite dev proxy; set for direct API calls)
VITE_API_BASE_URL=

# Backend CORS (dev frontend origin)
CORS_ORIGIN=http://localhost:3000
